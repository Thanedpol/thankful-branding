# ─── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Never expose to the client.
# Used by API routes for admin email lookup + signed press downloads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (contact form email notifications) ───────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Verified sender (e.g. notifications@yourdomain.com or onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Where contact submissions get emailed (the admin's inbox)
CONTACT_NOTIFY_EMAIL=thank@example.com

# ─── Admin access (passcode — NO email/password) ─────────────────────────────
# The admin dashboard at /admin is unlocked by this single secret passcode.
# Set it to something only you know. Required for admin to work.
ADMIN_PASSCODE=change-me-to-a-secret

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
